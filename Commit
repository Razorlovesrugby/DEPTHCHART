#header {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  border-bottom: 1px solid #1e293b;
  padding: 14px 24px; display: flex; align-items: center; gap: 14px; flex-shrink: 0;
}
#header-icon { width: 38px; height: 38px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; transition: background 0.3s; flex-shrink: 0; }
#header-title { font-size: 20px; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; }
#header-sub { font-size: 11px; color: #64748b; letter-spacing: 1px; margin-top: 1px; }

#layout { display: flex; flex: 1; overflow: hidden; }

#sidebar {
  width: 192px; background: #0d0d14; border-right: 1px solid #1e293b;
  padding: 10px 6px; display: flex; flex-direction: column; gap: 3px;
  overflow-y: auto; flex-shrink: 0;
}
#sidebar-label { font-size: 10px; letter-spacing: 2px; color: #475569; padding: 0 8px 8px; text-transform: uppercase; }

.pos-btn {
  border-radius: 6px; padding: 9px 10px; cursor: grab;
  display: flex; align-items: center; justify-content: space-between; gap: 8px;
  border: 1px solid transparent; border-left: 3px solid transparent;
  background: transparent; color: #64748b; transition: opacity 0.1s;
}
.pos-btn.ghost { opacity: 0.3; }
.pos-btn.drop-hi { border-top: 2px solid #64748b; }
.pos-btn.drop-lo { border-bottom: 2px solid #64748b; }

#main { flex: 1; padding: 20px 26px; overflow-y: auto; background: #0a0a0f; }
#pos-header { margin-bottom: 14px; display: flex; align-items: center; gap: 12px; }
#pos-abbr { color: #fff; font-weight: 900; font-size: 12px; letter-spacing: 2px; padding: 3px 12px; border-radius: 4px; text-transform: uppercase; }
#pos-name { font-size: 26px; font-weight: 900; letter-spacing: 1px; color: #f1f5f9; }
#pos-divider { flex: 1; height: 1px; }
#pos-count { font-size: 11px; color: #475569; letter-spacing: 1px; }

#legend { display: flex; gap: 16px; margin-bottom: 12px; }
.leg { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; display: flex; align-items: center; gap: 5px; }
.leg-dot { width: 7px; height: 7px; border-radius: 50%; }
.leg-desc { color: #334155; font-weight: 400; }

.sec-div { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.sec-div-lbl { font-size: 10px; font-weight: 700; letter-spacing: 2px; }
.sec-div-line { flex: 1; height: 1px; }

#player-list { display: flex; flex-direction: column; gap: 5px; }

.pcard {
  border-radius: 8px; padding: 10px 14px;
  display: flex; align-items: center; gap: 12px;
  cursor: grab; transition: box-shadow 0.1s;
  border-left-width: 3px; border-left-style: solid;
}
.pcard:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.35); }
.pcard.ghost { opacity: 0.25; }
.pcard.drop-hi { border-top: 2px solid #94a3b8 !important; }
.pcard.drop-lo { border-bottom: 2px solid #94a3b8 !important; }

.prank { width: 30px; height: 30px; border-radius: 6px; flex-shrink: 0; font-weight: 900; font-size: 15px; display: flex; align-items: center; justify-content: center; }
.pname { flex: 1; font-weight: 600; letter-spacing: 0.4px; }
.ptier { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; opacity: 0.85; }
.pbtn {
  background: transparent; border: 1px solid #1e293b; border-radius: 5px;
  padding: 3px 8px; color: #475569; font-size: 11px; font-weight: 700;
  cursor: pointer; letter-spacing: 0.5px; transition: all 0.15s;
}
.phandle { color: #475569; font-size: 18px; padding: 0 2px; }

#drag-clone {
  position: fixed; pointer-events: none; z-index: 9999;
  display: none; align-items: center; gap: 12px;
  border-radius: 8px; padding: 10px 14px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.7);
  transform: rotate(1.5deg) scale(1.02);
  font-family: 'Barlow Condensed', sans-serif; color: #e2e8f0;
  border-left-width: 3px; border-left-style: solid;
  transition: none;
}

#tip-box { margin-top: 18px; padding: 10px 14px; background: #0d0d14; border-radius: 8px; border: 1px solid #1e293b; font-size: 12px; color: #475569; }

#modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.78); align-items: center; justify-content: center; z-index: 100; }
#modal-overlay.open { display: flex; }
#modal { background: #0f0f1a; border: 1px solid #1e293b; border-radius: 12px; padding: 26px 28px; min-width: 300px; box-shadow: 0 24px 80px rgba(0,0,0,0.6); }
#modal-eyebrow { font-size: 10px; color: #475569; letter-spacing: 2px; margin-bottom: 5px; }
#modal-name { font-size: 22px; font-weight: 900; color: #f1f5f9; margin-bottom: 3px; }
#modal-current { font-size: 12px; color: #64748b; margin-bottom: 18px; }
#modal-positions { display: flex; flex-direction: column; gap: 5px; }
.mpos-btn { background: #131320; border-radius: 7px; padding: 9px 14px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; color: #cbd5e1; transition: all 0.15s; border-left-width: 3px; border-left-style: solid; border-top: 1px solid; border-right: 1px solid; border-bottom: 1px solid; }
#modal-cancel { margin-top: 14px; width: 100%; background: transparent; border: 1px solid #1e293b; border-radius: 7px; padding: 8px; color: #475569; cursor: pointer; font-size: 13px; font-weight: 600; }
#modal-cancel:hover { color: #94a3b8; }
